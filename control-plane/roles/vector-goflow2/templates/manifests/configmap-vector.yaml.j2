---
apiVersion: v1
kind: ConfigMap
metadata:
  name: vector-goflow2-config
  namespace: "{{ sflow_collector_namespace }}"
  labels:
    app: vector-goflow2
data:
  vector.yaml: |
    data_dir: /var/lib/vector

    enrichment_tables:
      geoip:
        type: mmdb
        path: /etc/vector/enrichment/geoip/geoip.mmdb

      well_known_ports:
        type: file
        file:
          path: /etc/vector/enrichment/well_known_ports.csv
          encoding:
            type: csv
        schema:
          port: integer
          protocol: string

      ifindex_vrf:
        type: file
        file:
          path: /etc/vector/enrichment/ifindex.csv
          encoding:
            type: csv
        schema:
          ifindex: integer
          interface: string
          vrf: string

    sources:
      goflow2_raw:
        type: file
        # Reading logs from the node directly, no access to kubeapi necessary
        include:
          - "/var/log/pods/{{ sflow_collector_namespace }}_goflow2-*_*/goflow2/*.log"

    transforms:
      parse_goflow2:
        type: remap
        inputs:
          - goflow2_raw
        source: |
          parsed_line, err = parse_regex(.message, r'^(?P<_ts>\S+) (?P<stream>\S+) \S+ (?P<content>.*)$')
          if err != null { abort }
          if parsed_line.stream != "stdout" { abort }

          parsed, err = parse_json(parsed_line.content)
          if err != null { abort }
          . = merge!(., parsed)

          # Forcing empty fields to zero
          .dst_port = to_int(.dst_port) ?? 0
          .src_port = to_int(.src_port) ?? 0
          .in_if    = to_int(.in_if)    ?? 0

          # goflow2 already emits proto as a string ("TCP", "UDP", "ICMPv6", etc.)
          .proto_name = string!(.proto)

          .app_proto        = "UNCLASSIFIED"
          .vrf              = "UNKNOWN"
          .sampler_address  = string(.sampler_address) ?? "UNKNOWN"

      enrich_proto:
        type: remap
        inputs:
          - parse_goflow2
        source: |
          # Flow monitoring typically samples uplink ingress, meaning that the dst port is most likely of interest
          # If neither port matches, the lower one is chosen
          row, err = get_enrichment_table_record("well_known_ports", { "port": .dst_port })
          if err == null {
            .app_proto = row.protocol
          } else {
            row, err = get_enrichment_table_record("well_known_ports", { "port": .src_port })
            if err == null {
              .app_proto = row.protocol
            } else {
              dst = to_int(.dst_port) ?? 0
              src = to_int(.src_port) ?? 0
              if dst > 0 && (src == 0 || dst <= src) {
                .app_proto = to_string(dst)
              } else if src > 0 {
                .app_proto = to_string(src)
              }
            }
          }

      enrich_vrf:
        type: remap
        inputs:
          - enrich_proto
        source: |
          row, err = get_enrichment_table_record("ifindex_vrf", { "ifindex": .in_if })
          if err == null {
            .vrf       = row.vrf
            .interface = row.interface
          }

      geo_sample:
        type: sample
        inputs:
          - enrich_vrf
        rate: {{ vector_goflow2_geo_sample_rate }}

      enrich_geo:
        type: remap
        inputs:
          - geo_sample
        source: |
          # Drop private, loopback, and link-local addresses. Useful in the lab, in production this can be avoided
          # by using a dedicated WAN facing sample stream.
          if (ip_cidr_contains("10.0.0.0/8",     .src_addr) ?? false) ||
             (ip_cidr_contains("172.16.0.0/12",  .src_addr) ?? false) ||
             (ip_cidr_contains("192.168.0.0/16", .src_addr) ?? false) ||
             (ip_cidr_contains("127.0.0.0/8",    .src_addr) ?? false) ||
             (ip_cidr_contains("169.254.0.0/16", .src_addr) ?? false) ||
             (ip_cidr_contains("::1/128",        .src_addr) ?? false) ||
             (ip_cidr_contains("fc00::/7",       .src_addr) ?? false) ||
             (ip_cidr_contains("fe80::/10",      .src_addr) ?? false) {
            abort
          }

          geo, err = get_enrichment_table_record("geoip", {"ip": .src_addr})
          if err == null {
            .country_code = string(geo.country.iso_code) ?? "UNKNOWN"
            .latitude     = to_float(geo.location.latitude) ?? 0.0
            .longitude    = to_float(geo.location.longitude) ?? 0.0
          } else {
            .country_code = "UNKNOWN"
            .latitude     = 0.0
            .longitude    = 0.0
          }

    sinks:
      loki_goflow2:
        type: loki
        inputs:
          - enrich_vrf
        endpoint: http://loki:3100
        encoding:
          codec: json
        labels:
          app: goflow2
          namespace: "{{ sflow_collector_namespace }}"
          proto_name:      "{{ '{{' }} .proto_name {{ '}}' }}"
          app_proto:       "{{ '{{' }} .app_proto {{ '}}' }}"
          vrf:             "{{ '{{' }} .vrf {{ '}}' }}"
          sampler_address: "{{ '{{' }} .sampler_address {{ '}}' }}"
        remove_label_fields: true
        healthcheck:
          enabled: false
        batch:
          max_bytes: 1048576
          timeout_secs: 5
        request:
          retry_attempts: 5
        buffer:
          type: memory
          max_events: 50000
          when_full: block

      loki_geo:
        type: loki
        inputs:
          - enrich_geo
        endpoint: http://loki:3100
        encoding:
          codec: json
        labels:
          app: goflow2-geo
          namespace: "{{ sflow_collector_namespace }}"
        remove_label_fields: false
        healthcheck:
          enabled: false
        batch:
          max_bytes: 524288
          timeout_secs: 10
        request:
          retry_attempts: 5
        buffer:
          type: memory
          max_events: 10000
          when_full: block
