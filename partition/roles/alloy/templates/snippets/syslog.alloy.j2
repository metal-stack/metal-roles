local.file_match "syslog" {
	path_targets = [{
		__path__  = "/var/log/syslog",
		job       = "syslog",
		partition = "{{ metal_partition_id }}",
		host      = "{{ inventory_hostname }}",
	}]
}

loki.source.file "syslog" {
	targets               = local.file_match.syslog.targets
	forward_to            = [loki.write.default.receiver]
	// read once on first start after migration to resume from where promtail left off;
	// ignored if the file does not exist. alloy then tracks positions in its own wal.
	// https://grafana.com/docs/alloy/latest/reference/components/loki/loki.source.file/#arguments
	legacy_positions_file = "{{ alloy_syslog_legacy_positions_file }}"
}
