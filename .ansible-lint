---
skip_list:
  - galaxy[no-changelog]
  - yaml[line-length]

exclude_paths:
  - .cache/
  - .github/
  # these are template results, so they do not need formatting:
  - partition/roles/sonic/test/data/**/metal.yaml

# TODO: we need to gradually fix these!
warn_list:
  - role-name
  - key-order
  - schema
  - name
  - var-naming
  - package-latest
  - risky-file-permissions
  - risky-octal
  - risky-shell-pipe
  - no-changed-when
  - no-handler
  - fqcn
